import React, { useState, useEffect, useMemo } from 'react';
import { initializeApp } from 'firebase/app';
import { 
  getAuth, 
  signInAnonymously, 
  signInWithCustomToken, 
  onAuthStateChanged,
} from 'firebase/auth';
import { 
  getFirestore, 
  doc, 
  setDoc, 
  onSnapshot, 
} from 'firebase/firestore';
import { 
  BookOpen, 
  Dna, 
  Plus, 
  Trash2, 
  ChevronRight, 
  ChevronLeft,
  ChevronDown, 
  User, 
  Edit3,
  Layers,
  X,
  LogOut,
  Image as ImageIcon,
  Heart,
  Clock,
  AlertTriangle,
  Zap,
  Shield,
  Users,
  Sparkles,
  Command,
  Activity
} from 'lucide-react';

// --- Firebase Configuration ---
const firebaseConfig = JSON.parse(__firebase_config);
const app = initializeApp(firebaseConfig);
const auth = getAuth(app);
const db = getFirestore(app);
const appId = typeof __app_id !== 'undefined' ? __app_id : 'anodite-terminal-v13';

const INITIAL_STATE = {
  chronicles: [], 
  codex: [],
  meta: { lastUpdate: Date.now(), title: "ANODITE CHRONICLES" }
};

export default function App() {
  const [user, setUser] = useState(null);
  const [authLoading, setAuthLoading] = useState(true);
  const [isLogged, setIsLogged] = useState(false);
  const [loginForm, setLoginForm] = useState({ id: 'Scarlett', key: 'Keyan@5184' });
  const [viewMode, setViewMode] = useState('read'); 
  const [editModule, setEditModule] = useState('codex'); 
  const [data, setData] = useState(INITIAL_STATE);
  const [syncStatus, setSyncStatus] = useState('online');
  const [sidebarOpen, setSidebarOpen] = useState(true);
  const [readNavOpen, setReadNavOpen] = useState(true);
  
  // Selection States
  const [selCodexId, setSelCodexId] = useState(null);
  const [selArcId, setSelArcId] = useState(null);
  const [selEpId, setSelEpId] = useState(null);
  const [selPgId, setSelPgId] = useState(null);
  const [activeBioId, setActiveBioId] = useState(null);
  const [readPhase, setReadPhase] = useState('title');

  // Modal for deletions
  const [confirmModal, setConfirmModal] = useState(null);

  // --- Auth & Sync ---
  useEffect(() => {
    const initAuth = async () => {
      try {
        if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
          await signInWithCustomToken(auth, __initial_auth_token);
        } else {
          await signInAnonymously(auth);
        }
      } catch (e) { console.error(e); } finally { setAuthLoading(false); }
    };
    initAuth();
    const unsub = onAuthStateChanged(auth, u => setUser(u));
    return () => unsub();
  }, []);

  useEffect(() => {
    if (!user) return;
    const docRef = doc(db, 'artifacts', appId, 'users', user.uid, 'data', 'terminal_state_v13');
    return onSnapshot(docRef, snap => {
      if (snap.exists()) setData(prev => ({ ...prev, ...snap.data() }));
      else setDoc(docRef, INITIAL_STATE);
    }, (err) => console.error(err));
  }, [user]);

  const save = async (newData) => {
    if (!user) return;
    setSyncStatus('syncing');
    try {
      await setDoc(doc(db, 'artifacts', appId, 'users', user.uid, 'data', 'terminal_state_v13'), newData);
      setSyncStatus('online');
    } catch (e) { setSyncStatus('error'); }
  };

  const handleLogout = () => {
    setIsLogged(false);
    setLoginForm({ id: '', key: '' });
  };

  const triggerConfirm = (message, onConfirm) => {
    setConfirmModal({ message, onConfirm });
  };

  if (authLoading) return <LoadingScreen />;
  if (!isLogged) return <LoginScreen form={loginForm} setForm={setLoginForm} onLogin={() => setIsLogged(true)} />;

  return (
    <div className="h-screen w-full flex bg-[#030005] text-fuchsia-100 overflow-hidden font-sans selection:bg-fuchsia-500/30">
      {/* Background Mana Environment */}
      <div className="absolute inset-0 opacity-20 mana-grid pointer-events-none animate-mana-pulse" />
      <div className="absolute top-0 left-1/4 w-[500px] h-[500px] bg-fuchsia-600/10 rounded-full blur-[120px] pointer-events-none animate-pulse" />
      <div className="absolute bottom-0 right-1/4 w-[600px] h-[600px] bg-purple-900/10 rounded-full blur-[150px] pointer-events-none animate-pulse delay-1000" />

      {/* Main Mode Sidebar */}
      <nav className={`${sidebarOpen ? 'w-24' : 'w-0 overflow-hidden'} border-r border-fuchsia-900/30 bg-black/80 flex flex-col items-center py-8 z-50 backdrop-blur-3xl shrink-0 transition-all duration-700 relative`}>
         <div className="mb-12 cursor-pointer group relative" onClick={() => { setViewMode('read'); setReadPhase('title'); }}>
            <OmnitrixLogo size={44} active={viewMode === 'read'} />
         </div>

         <div className="flex flex-col gap-6 w-full px-2 flex-1">
            <NavBtn active={viewMode === 'read'} onClick={() => setViewMode('read')} icon={BookOpen} label="READ" />
            <NavBtn active={viewMode === 'edit'} onClick={() => setViewMode('edit')} icon={Edit3} label="EDIT" />
            
            {/* Sub-navigation for Edit Mode */}
            {viewMode === 'edit' && (
              <div className="flex flex-col gap-4 w-full pt-4 animate-in slide-in-from-top-4 duration-500">
                <div className="h-px w-8 bg-fuchsia-900/30 mx-auto" />
                <NavBtn active={editModule === 'codex'} onClick={() => setEditModule('codex')} icon={Dna} label="CODEX" sub />
                <NavBtn active={editModule === 'story'} onClick={() => setEditModule('story')} icon={Layers} label="STORY" sub />
              </div>
            )}
         </div>

         <button onClick={handleLogout} className="mt-auto p-4 text-fuchsia-900 hover:text-red-500 transition-colors group">
            <LogOut size={22} className="group-hover:scale-110 transition-transform" />
            <span className="block text-[7px] font-black mt-2 tracking-widest">LOGOUT</span>
         </button>
      </nav>

      {/* Sidebar Toggle Arrow */}
      <button 
        onClick={() => setSidebarOpen(!sidebarOpen)}
        className="absolute left-0 top-1/2 -translate-y-1/2 z-[60] bg-fuchsia-600/10 hover:bg-fuchsia-600/30 text-fuchsia-400 p-1.5 rounded-r-xl border border-l-0 border-fuchsia-500/20 transition-all hover:pl-3"
        style={{ transform: `translateY(-50%) translateX(${sidebarOpen ? '96px' : '0px'})` }}
      >
        {sidebarOpen ? <ChevronLeft size={18} /> : <ChevronRight size={18} />}
      </button>

      <main className="flex-1 flex flex-col min-w-0 relative">
        <header className="h-16 border-b border-fuchsia-900/20 flex items-center justify-between px-8 bg-black/40 backdrop-blur-xl shrink-0 z-40">
           <div className="flex items-center gap-6">
              <div className="flex flex-col">
                <span className="text-[10px] font-black tracking-[0.5em] text-fuchsia-500 uppercase leading-none">{viewMode}</span>
                <span className="text-[8px] font-mono text-fuchsia-900/60 mt-1 uppercase tracking-widest">Protocol 13.0.4</span>
              </div>
              <div className="w-px h-6 bg-fuchsia-900/30" />
              <span className="text-[11px] font-black tracking-[0.4em] text-white uppercase animate-mana-flicker flex items-center gap-3">
                {viewMode === 'edit' ? (
                  <>
                    <Activity size={12} className="text-fuchsia-500" />
                    {editModule} module
                  </>
                ) : readPhase}
              </span>
           </div>
           
           <div className="flex items-center gap-6">
              <div className="hidden md:flex items-center gap-2 px-3 py-1.5 rounded-full bg-fuchsia-500/5 border border-fuchsia-500/10">
                 <Sparkles size={12} className="text-fuchsia-400 animate-pulse" />
                 <span className="text-[8px] font-black text-fuchsia-400/80 tracking-widest uppercase">Mana Field Stable</span>
              </div>
              <div className="flex items-center gap-2">
                 <div className={`w-1.5 h-1.5 rounded-full ${syncStatus === 'online' ? 'bg-fuchsia-500 shadow-[0_0_8px_#d946ef]' : 'bg-red-500 animate-ping'}`} />
                 <span className="text-[8px] font-mono text-fuchsia-900 uppercase font-bold tracking-widest">{syncStatus}</span>
              </div>
           </div>
        </header>

        <div className="flex-1 overflow-hidden relative">
          {viewMode === 'read' ? (
            <div className="h-full flex relative">
              <div className={`${readNavOpen ? 'w-56 translate-x-0' : 'w-0 -translate-x-full overflow-hidden'} border-r border-fuchsia-900/20 bg-black/60 flex flex-col py-10 shrink-0 transition-all duration-500 ease-in-out z-30`}>
                <p className="text-[9px] font-black tracking-[0.3em] text-fuchsia-900 px-8 mb-10 uppercase">Chronicle Flow</p>
                <div className="flex flex-col gap-2">
                  <PhaseLink active={readPhase === 'title'} onClick={() => setReadPhase('title')} label="Cover" />
                  <PhaseLink active={readPhase === 'codex'} onClick={() => setReadPhase('codex')} label="Codex" />
                  <PhaseLink active={readPhase === 'index'} onClick={() => setReadPhase('index')} label="Index" />
                  <PhaseLink active={readPhase === 'story'} onClick={() => setReadPhase('story')} label="Logs" />
                </div>
                
                <div className="mt-auto px-8 pb-8">
                  <div className="p-4 rounded-2xl bg-fuchsia-500/5 border border-fuchsia-500/10 space-y-3">
                    <p className="text-[7px] font-black text-fuchsia-800 uppercase tracking-widest text-center">Encryption Runes</p>
                    <div className="flex justify-around opacity-40">
                      <Rune char="A" /> <Rune char="B" /> <Rune char="C" />
                    </div>
                  </div>
                </div>
              </div>

              <button 
                onClick={() => setReadNavOpen(!readNavOpen)}
                className="absolute left-0 top-1/2 -translate-y-1/2 z-40 bg-black/80 text-fuchsia-500 p-1 rounded-r-lg border border-fuchsia-900/30 transition-all hover:bg-fuchsia-900/40"
                style={{ left: readNavOpen ? '224px' : '0px' }}
              >
                {readNavOpen ? <ChevronLeft size={16} /> : <ChevronRight size={16} />}
              </button>

              <div className="flex-1 overflow-y-auto custom-scrollbar relative bg-black/20">
                <ReadMode 
                  data={data} 
                  phase={readPhase}
                  setPhase={setReadPhase}
                  selection={{selArcId, setSelArcId, selEpId, setSelEpId, selPgId, setSelPgId}} 
                  setActiveBioId={setActiveBioId} 
                />
              </div>
            </div>
          ) : (
            <div className="h-full flex overflow-hidden">
              {editModule === 'codex' && <CodexEditor data={data} onSave={save} selection={{selCodexId, setSelCodexId}} triggerConfirm={triggerConfirm} />}
              {editModule === 'story' && <StoryEditor data={data} onSave={save} selection={{selArcId, setSelArcId, selEpId, setSelEpId, selPgId, setSelPgId}} triggerConfirm={triggerConfirm} />}
            </div>
          )}
        </div>
      </main>

      {/* Overlays */}
      {activeBioId && (
        <BiometricModal 
          char={data.codex.find(c => c.id === activeBioId)} 
          allChars={data.codex}
          onClose={() => setActiveBioId(null)} 
        />
      )}

      {confirmModal && (
        <div className="fixed inset-0 z-[200] flex items-center justify-center p-6 animate-in fade-in duration-300">
           <div className="absolute inset-0 bg-black/90 backdrop-blur-2xl" onClick={() => setConfirmModal(null)} />
           <div className="relative glass-panel p-10 rounded-[2.5rem] max-w-md w-full text-center space-y-8 border-fuchsia-500/40 shadow-[0_0_50px_rgba(217,70,239,0.1)]">
              <div className="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto text-red-500 border border-red-500/20">
                <AlertTriangle size={36} className="animate-pulse" />
              </div>
              <div className="space-y-2">
                <h3 className="text-white font-black uppercase tracking-[0.2em]">Confirm Erasure</h3>
                <p className="text-fuchsia-100/60 font-serif italic text-lg leading-relaxed">{confirmModal.message}</p>
              </div>
              <div className="flex gap-4">
                 <button onClick={() => setConfirmModal(null)} className="flex-1 py-4 rounded-2xl bg-white/5 text-fuchsia-900 font-black uppercase text-[10px] tracking-widest hover:bg-white/10 transition-all">Cancel</button>
                 <button onClick={() => { confirmModal.onConfirm(); setConfirmModal(null); }} className="flex-1 py-4 rounded-2xl bg-red-600 text-white font-black uppercase text-[10px] tracking-widest hover:bg-red-500 transition-all shadow-lg shadow-red-900/20">Purge Data</button>
              </div>
           </div>
        </div>
      )}

      <style>{`
        @keyframes mana-pulse {
          0%, 100% { opacity: 0.15; transform: scale(1); }
          50% { opacity: 0.25; transform: scale(1.02); }
        }
        @keyframes mana-flicker {
          0%, 100% { opacity: 1; text-shadow: 0 0 10px rgba(217, 70, 239, 0.5); }
          95% { opacity: 1; text-shadow: 0 0 10px rgba(217, 70, 239, 0.5); }
          97% { opacity: 0.7; text-shadow: 0 0 2px rgba(217, 70, 239, 0.2); }
          98% { opacity: 1; text-shadow: 0 0 10px rgba(217, 70, 239, 0.8); }
        }
        @keyframes floating {
          0%, 100% { transform: translateY(0); }
          50% { transform: translateY(-10px); }
        }
        @keyframes rune-spin {
          0% { transform: rotate(45deg) scale(1); }
          50% { transform: rotate(45deg) scale(1.1); filter: brightness(1.5); }
          100% { transform: rotate(45deg) scale(1); }
        }
        .animate-mana-pulse { animation: mana-pulse 8s infinite ease-in-out; }
        .animate-mana-flicker { animation: mana-flicker 5s infinite; }
        .animate-floating { animation: floating 4s infinite ease-in-out; }
        .animate-rune { animation: rune-spin 3s infinite ease-in-out; }
        
        .mana-grid {
          background-image: linear-gradient(to right, #d946ef08 1px, transparent 1px), linear-gradient(to bottom, #d946ef08 1px, transparent 1px);
          background-size: 60px 60px;
        }
        .custom-scrollbar::-webkit-scrollbar { width: 5px; height: 5px; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #d946ef44; border-radius: 10px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .glass-panel { background: rgba(5, 0, 10, 0.7); backdrop-filter: blur(40px); border: 1px solid rgba(217, 70, 239, 0.15); }
        
        .omnitrix-spin { animation: omni-rotate 20s infinite linear; }
        @keyframes omni-rotate {
          from { transform: rotate(0deg); }
          to { transform: rotate(360deg); }
        }
      `}</style>
    </div>
  );
}

// --- SHARED UI COMPONENTS ---

