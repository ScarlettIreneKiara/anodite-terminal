  return (
    <div className={`relative group transition-transform duration-700 ${active ? 'scale-110' : 'hover:scale-105'}`}>
      <svg width={size} height={size} viewBox="0 0 100 100" className={active ? 'omnitrix-spin' : ''}>
        <circle cx="50" cy="50" r="48" stroke="#d946ef" strokeWidth="1" strokeDasharray="4 4" fill="none" opacity="0.3" />
        <circle cx="50" cy="50" r="42" stroke="#d946ef" strokeWidth="2" fill="none" opacity="0.6" />
        <path d="M25 25 L75 75 M75 25 L25 75" stroke="#d946ef" strokeWidth="12" strokeLinecap="round" opacity={active ? 1 : 0.4} />
        <circle cx="50" cy="50" r="8" fill="#fff" className={active ? 'animate-pulse' : ''} />
      </svg>
      {active && (
        <div className="absolute inset-0 bg-fuchsia-500/20 blur-xl rounded-full -z-10 animate-pulse" />
      )}
