// --- CODEX EDITOR ---

function CodexEditor({ data, onSave, selection, triggerConfirm }) {
  const { selCodexId, setSelCodexId } = selection;
  const current = data.codex.find(c => c.id === selCodexId);
  const [activeTab, setActiveTab] = useState('bio');

  const update = (field, val) => {
    const newData = {...data};
    const idx = newData.codex.findIndex(c => c.id === selCodexId);
    newData.codex[idx] = { ...newData.codex[idx], [field]: val };
    onSave(newData);
  };

  const add = () => {
    const id = crypto.randomUUID();
    onSave({...data, codex: [...data.codex, { 
      id, 
      name: 'NEW_SUBJECT', 
      alias: '', 
      images: [], 
      weapons: [], 
      relationships: [], 
      personality: '', 
      traits: [],
      species: '',
      gender: '',
      age: ''
    }]});
    setSelCodexId(id);
  };

  const remove = (id) => {
    triggerConfirm("Erase this subject from the biometric database?", () => {
        onSave({...data, codex: data.codex.filter(x => x.id !== id)});
        if (selCodexId === id) setSelCodexId(null);
    });
  };

  return (
    <div className="flex-1 flex flex-col md:flex-row h-full overflow-hidden bg-black/40">
      <aside className="w-full md:w-80 border-r border-fuchsia-900/10 flex flex-col shrink-0 bg-black/60 z-20">
        <div className="p-8 border-b border-fuchsia-900/10 flex justify-between items-center bg-black/40">
           <div className="flex flex-col">
            <span className="text-[10px] font-black tracking-[0.3em] text-fuchsia-800 uppercase">Biometric Archive</span>
            <span className="text-[7px] font-mono text-fuchsia-900 uppercase">Registry V13</span>
           </div>
           <button onClick={add} className="p-3 bg-fuchsia-500/10 text-fuchsia-400 rounded-xl hover:bg-fuchsia-500/20 transition-all border border-fuchsia-500/10 active:scale-95"><Plus size={20} /></button>
        </div>
        <div className="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-3">
           {data.codex.map(c => (
             <div key={c.id} onClick={() => setSelCodexId(c.id)} className={`p-5 rounded-2xl cursor-pointer transition-all border relative group ${selCodexId === c.id ? 'bg-fuchsia-500/10 border-fuchsia-500/40 shadow-lg shadow-fuchsia-900/10' : 'border-transparent hover:bg-fuchsia-900/10'}`}>
                <div className="flex items-center gap-4">
                   <div className={`w-10 h-10 rounded-xl bg-black flex items-center justify-center border transition-colors ${selCodexId === c.id ? 'border-fuchsia-500/60' : 'border-fuchsia-900/20'}`}>
                      {c.images?.[0] ? <img src={c.images[0]} className="w-full h-full object-cover rounded-xl" /> : <User size={16} className="text-fuchsia-900" />}
                   </div>
                   <div className="min-w-0">
                      <p className={`text-[11px] font-black uppercase truncate pr-8 ${selCodexId === c.id ? 'text-white' : 'text-fuchsia-900'}`}>{c.name}</p>
                      <p className="text-[7px] font-mono text-fuchsia-900 uppercase mt-1 tracking-widest">{c.alias || 'Classified'}</p>
                   </div>
                </div>
                <button onClick={(e) => { e.stopPropagation(); remove(c.id); }} className="absolute top-1/2 -translate-y-1/2 right-6 opacity-0 group-hover:opacity-100 text-red-900 hover:text-red-500 transition-all"><Trash2 size={14}/></button>
             </div>
           ))}
        </div>
      </aside>

      <div className="flex-1 overflow-y-auto custom-scrollbar bg-black/20">
        {current ? (
          <div className="max-w-5xl mx-auto p-12 lg:p-24 space-y-16 animate-in fade-in duration-700">
             <div className="flex flex-col lg:flex-row items-center gap-12 border-b border-fuchsia-900/10 pb-16">
                <div className="w-40 h-40 rounded-[2.5rem] bg-black border-2 border-fuchsia-500/30 flex items-center justify-center relative group overflow-hidden shrink-0 shadow-2xl">
                   {current.images?.[0] ? <img src={current.images[0]} className="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700" alt="Avatar" /> : <User size={50} className="text-fuchsia-900" />}
