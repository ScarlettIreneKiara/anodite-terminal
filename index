      </span>
      {active && <div className="absolute inset-y-0 left-0 w-1.5 bg-fuchsia-500 shadow-[0_0_15px_#d946ef]" />}
      <div className={`absolute inset-0 bg-fuchsia-500/5 transition-transform duration-500 origin-left ${active ? 'scale-x-100' : 'scale-x-0 group-hover:scale-x-100'}`} />
    </button>
  );
}

