             </div>

             <div className="flex flex-wrap gap-4 border-b border-fuchsia-900/10 pb-8">
                <TabBtn active={activeTab === 'bio'} icon={User} label="Biology" onClick={() => setActiveTab('bio')} />
                <TabBtn active={activeTab === 'personality'} icon={Sparkles} label="Persona" onClick={() => setActiveTab('personality')} />
                <TabBtn active={activeTab === 'gear'} icon={Shield} label="Arsenal" onClick={() => setActiveTab('gear')} />
                <TabBtn active={activeTab === 'social'} icon={Users} label="Relations" onClick={() => setActiveTab('social')} />
             </div>

             <div className="animate-in fade-in slide-in-from-bottom-4 duration-500">
                {activeTab === 'bio' && (
                  <div className="space-y-12">
                     <div className="grid grid-cols-1 md:grid-cols-3 gap-10">
                        <Input label="Biological Gender" value={current.gender} onChange={v => update('gender', v)} />
                        <Input label="Chronological Age" value={current.age} onChange={v => update('age', v)} />
                        <Input label="Species Origin" value={current.species} onChange={v => update('species', v)} />
                     </div>
                     <div className="space-y-4">
                        <label className="text-[10px] font-black uppercase text-fuchsia-900 tracking-[0.3em] ml-2">Anatomical / Historical Records</label>
                        <textarea 
                          value={current.powerDesc} 
                          onChange={e => update('powerDesc', e.target.value)} 
                          className="w-full bg-black/60 border border-fuchsia-900/20 rounded-3xl p-8 text-fuchsia-100/70 outline-none min-h-[250px] focus:border-fuchsia-500/40 font-serif text-lg leading-relaxed shadow-inner" 
                          placeholder="Comprehensive history and biological capabilities..." 
                        />
                     </div>
                  </div>
                )}

                {activeTab === 'personality' && (
                  <div className="space-y-12">
                     <div className="space-y-4">
                        <label className="text-[10px] font-black uppercase text-fuchsia-900 tracking-[0.3em] ml-2">Psychological Profile</label>
                        <textarea 
                          value={current.personality || ''} 
                          onChange={e => update('personality', e.target.value)} 
                          className="w-full bg-black/60 border border-fuchsia-900/20 rounded-3xl p-8 text-fuchsia-100/70 outline-none min-h-[300px] focus:border-fuchsia-500/40 font-serif text-lg leading-relaxed shadow-inner" 
                          placeholder="Describe behavior, alignment, motivations and fears..." 
                        />
                     </div>
                     <div className="p-8 rounded-3xl bg-fuchsia-500/5 border border-fuchsia-500/10">
                        <p className="text-[9px] font-black text-fuchsia-500 uppercase mb-4 tracking-widest flex items-center gap-2">
                           <Sparkles size={12} /> Neural Traits
                        </p>
                        <div className="flex flex-wrap gap-3">
                           {current.traits?.map((t, i) => (
                             <div key={i} className="px-5 py-2 rounded-full bg-fuchsia-500/10 border border-fuchsia-500/20 text-[10px] font-black text-fuchsia-400 uppercase tracking-widest flex items-center gap-3">
                                {t}
                                <button onClick={() => update('traits', current.traits.filter((_, idx) => idx !== i))} className="hover:text-red-500"><X size={12}/></button>
                             </div>
                           ))}
                           <button onClick={() => {
                             const t = prompt("Enter trait:");
                             if(t) update('traits', [...(current.traits || []), t]);
                           }} className="px-5 py-2 rounded-full border border-dashed border-fuchsia-900/40 text-[10px] font-black text-fuchsia-900 uppercase tracking-widest hover:border-fuchsia-500 hover:text-fuchsia-500 transition-all">+ Add Trait</button>
                        </div>
                     </div>
                  </div>
                )}

                {activeTab === 'gear' && (
                  <div className="space-y-12">
                    <div className="flex justify-between items-center mb-6">
                       <h3 className="text-2xl font-black text-white uppercase tracking-tight flex items-center gap-4">
                         <Shield size={24} className="text-fuchsia-500" />
                         Combat Arsenal
                       </h3>
                       <button onClick={() => update('weapons', [...(current.weapons || []), { id: crypto.randomUUID(), name: 'New Weapon', desc: '' }])} className="px-6 py-2 bg-fuchsia-600/20 border border-fuchsia-500/30 rounded-full text-[10px] font-black text-fuchsia-400 uppercase hover:bg-fuchsia-600 hover:text-white transition-all">+ Add Weaponry</button>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
