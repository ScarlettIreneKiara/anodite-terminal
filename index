// --- HELPERS ---

function Input({ label, value, onChange }) {
  return (
    <div className="space-y-4">
       <label className="text-[10px] font-black uppercase text-fuchsia-900 tracking-[0.4em] ml-2">{label}</label>
       <input value={value} onChange={e => onChange(e.target.value)} className="w-full bg-black/60 border border-fuchsia-900/30 p-6 rounded-[2rem] text-fuchsia-100 outline-none focus:border-fuchsia-500/60 focus:bg-fuchsia-500/5 transition-all font-serif text-lg shadow-inner" />
    </div>
  );
}

function Stat({ icon: Icon, label, val }) {
  return (
    <div className="space-y-4 text-center md:text-left">
       <div className="flex items-center justify-center md:justify-start gap-3 text-fuchsia-900">
          <Icon size={16} />
          <span className="text-[9px] font-black uppercase tracking-[0.3em]">{label}</span>
       </div>
       <p className="text-white font-serif italic text-2xl tracking-tight">{val || 'N/A'}</p>
    </div>
  );
}
