    <div className="h-screen bg-[#030005] flex flex-col items-center justify-center space-y-12">
      <div className="relative">
        <div className="absolute inset-0 bg-fuchsia-500/20 blur-3xl animate-pulse rounded-full" />
        <OmnitrixLogo size={120} active={true} />
