                      <ImageIcon size={24} className="text-fuchsia-500 mb-2" />
                      <span className="text-[9px] font-black text-white uppercase tracking-widest">Update Visual</span>
                      <input type="file" className="hidden" multiple onChange={e => {
                         const files = Array.from(e.target.files);
                         files.forEach(f => {
                            const r = new FileReader();
                            r.onload = () => update('images', [...(current.images || []), r.result]);
                            r.readAsDataURL(f);
                         });
                      }} />
                   </label>
                </div>
                <div className="flex-1 space-y-6 text-center lg:text-left">
                   <div className="space-y-2">
                     <p className="text-[10px] font-black text-fuchsia-500 uppercase tracking-[0.5em] opacity-40">Subject Identification</p>
                     <input 
                       value={current.name} 
                       onChange={e => update('name', e.target.value)} 
                       className="bg-transparent border-none text-6xl font-black text-white outline-none w-full focus:text-fuchsia-400 transition-colors uppercase tracking-tighter" 
                       placeholder="NAME"
                     />
                   </div>
                   <input 
                     value={current.alias} 
                     onChange={e => update('alias', e.target.value)} 
                     placeholder="OPERATIONAL ALIAS..."
