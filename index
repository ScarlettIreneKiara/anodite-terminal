function StoryEditor({ data, onSave, selection, triggerConfirm }) {
  const { selArcId, setSelArcId, selEpId, setSelEpId, selPgId, setSelPgId } = selection;
  const arc = data.chronicles.find(a => a.id === selArcId);
  const ep = arc?.episodes.find(e => e.id === selEpId);
  const pg = ep?.pages.find(p => p.id === selPgId);

  const addVolume = () => {
    const id = crypto.randomUUID();
    onSave({ ...data, chronicles: [...data.chronicles, { id, title: 'New Volume', episodes: [] }] });
    setSelArcId(id);
  };

  const addChapter = (arcId) => {
    const id = crypto.randomUUID();
    const next = data.chronicles.map(a => a.id === arcId ? { ...a, episodes: [...a.episodes, { id, title: 'New Chapter', pages: [] }] } : a);
    onSave({ ...data, chronicles: next });
    setSelEpId(id);
  };

  const addLog = (arcId, epId) => {
    const id = crypto.randomUUID();
    const next = data.chronicles.map(a => {
        if (a.id === arcId) {
            return { ...a, episodes: a.episodes.map(e => e.id === epId ? { ...e, pages: [...e.pages, { id, title: 'New Entry', content: '' }] } : e) };
        }
        return a;
    });
    onSave({ ...data, chronicles: next });
    setSelPgId(id);
  };

  const deleteVolume = (id) => {
    triggerConfirm("Erase this entire Volume and all its contents?", () => {
        onSave({ ...data, chronicles: data.chronicles.filter(a => a.id !== id) });
        if (selArcId === id) { setSelArcId(null); setSelEpId(null); setSelPgId(null); }
    });
  };

  const deleteChapter = (arcId, epId) => {
    triggerConfirm("Delete this Chapter?", () => {
        onSave({ ...data, chronicles: data.chronicles.map(a => a.id === arcId ? { ...a, episodes: a.episodes.filter(e => e.id !== epId) } : a) });
        if (selEpId === epId) { setSelEpId(null); setSelPgId(null); }
    });
  };

  const deleteLog = (arcId, epId, pgId) => {
    triggerConfirm("Permanently erase this chronicle entry?", () => {
        onSave({ ...data, chronicles: data.chronicles.map(a => a.id === arcId ? { ...a, episodes: a.episodes.map(e => e.id === epId ? { ...e, pages: e.pages.filter(p => p.id !== pgId) } : e) } : a) });
        if (selPgId === pgId) setSelPgId(null);
    });
  };

  return (
    <div className="flex-1 flex flex-col md:flex-row h-full overflow-hidden bg-black/40">
      <aside className="w-full md:w-80 border-r border-fuchsia-900/10 flex flex-col shrink-0 bg-black/60 z-20">
        <div className="p-8 border-b border-fuchsia-900/10 flex justify-between items-center bg-black/40">
           <div className="flex flex-col">
            <span className="text-[10px] font-black tracking-[0.3em] text-fuchsia-800 uppercase">Story Lattice</span>
            <span className="text-[7px] font-mono text-fuchsia-900 uppercase">Chronicle Core</span>
           </div>
           <button onClick={addVolume} className="p-3 bg-fuchsia-500/10 text-fuchsia-400 rounded-xl hover:bg-fuchsia-500/20 transition-all active:scale-95 border border-fuchsia-500/10"><Plus size={20} /></button>
        </div>
        <div className="flex-1 overflow-y-auto custom-scrollbar p-6 space-y-4">
           {data.chronicles.map((a) => (
             <div key={a.id} className="space-y-3">
                <div onClick={() => setSelArcId(a.id === selArcId ? null : a.id)} className={`group flex items-center justify-between p-4 rounded-2xl cursor-pointer transition-all border ${selArcId === a.id ? 'bg-fuchsia-500/10 border-fuchsia-500/40' : 'hover:bg-fuchsia-900/10 border-transparent'}`}>
                   <input 
                     value={a.title} 
                     onClick={e => e.stopPropagation()}
                     onChange={e => onSave({...data, chronicles: data.chronicles.map(x => x.id === a.id ? {...x, title: e.target.value} : x)})}
                     className={`bg-transparent border-none outline-none font-black text-[11px] uppercase w-full cursor-pointer transition-colors ${selArcId === a.id ? 'text-white' : 'text-fuchsia-900'}`}
                   />
                   <div className="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button onClick={(e) => { e.stopPropagation(); deleteVolume(a.id); }} className="p-1 text-red-900 hover:text-red-500 transition-colors"><Trash2 size={14}/></button>
                      <ChevronDown size={16} className={`text-fuchsia-900 transition-transform ${selArcId === a.id ? 'rotate-180' : ''}`} />
                   </div>
                </div>
                {selArcId === a.id && (
                  <div className="ml-4 border-l-2 border-fuchsia-900/20 pl-6 space-y-6 pt-2 animate-in slide-in-from-left-2">
                     {a.episodes.map((e) => (
                       <div key={e.id} className="space-y-3">
                          <div onClick={() => setSelEpId(e.id === selEpId ? null : e.id)} className={`group flex items-center justify-between cursor-pointer py-1 ${selEpId === e.id ? 'text-fuchsia-400' : 'text-fuchsia-900 hover:text-fuchsia-500'}`}>
                            <input 
                               value={e.title} 
                               onClick={evt => evt.stopPropagation()}
                               onChange={evt => onSave({...data, chronicles: data.chronicles.map(x => x.id === a.id ? {...x, episodes: x.episodes.map(y => y.id === e.id ? {...y, title: evt.target.value} : y)} : x)})}
                               className="bg-transparent border-none outline-none font-black text-[10px] uppercase w-full cursor-pointer"
                            />
                            <div className="flex gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <button onClick={(evt) => { evt.stopPropagation(); deleteChapter(a.id, e.id); }} className="p-1 text-red-900 hover:text-red-500 transition-colors"><Trash2 size={12}/></button>
                                <ChevronRight size={14} className={`transition-transform ${selEpId === e.id ? 'rotate-90' : ''}`} />
                            </div>
                          </div>
                          {selEpId === e.id && (
                            <div className="space-y-2 pl-2 animate-in slide-in-from-top-1">
                               {e.pages.map((p) => (
                                 <div key={p.id} className="flex group items-center">
                                    <button onClick={() => setSelPgId(p.id)} className={`flex-1 text-left px-4 py-3 rounded-xl text-[9px] font-black uppercase transition-all truncate border ${selPgId === p.id ? 'bg-fuchsia-600 text-white border-fuchsia-500 shadow-lg shadow-fuchsia-900/20' : 'text-fuchsia-900 border-transparent hover:bg-fuchsia-900/20 hover:text-fuchsia-400'}`}>
                                      {p.title}
                                    </button>
                                    <button onClick={() => deleteLog(a.id, e.id, p.id)} className="opacity-0 group-hover:opacity-100 p-2 text-red-900 hover:text-red-500 transition-all"><Trash2 size={12}/></button>
                                 </div>
                               ))}
                               <button onClick={() => addLog(a.id, e.id)} className="w-full text-center border-2 border-dashed border-fuchsia-900/20 rounded-xl py-3 mt-4 text-[8px] font-black text-fuchsia-900 hover:text-fuchsia-400 hover:border-fuchsia-500/40 tracking-[0.3em] uppercase transition-all">+ New Log Sequence</button>
                            </div>
                          )}
                       </div>
                     ))}
                     <button onClick={() => addChapter(a.id)} className="w-full text-left py-3 text-[9px] font-black text-fuchsia-700 hover:text-fuchsia-400 uppercase tracking-[0.3em] transition-all">+ Add Chapter</button>
                  </div>
                )}
             </div>
           ))}
        </div>
      </aside>

      <div className="flex-1 overflow-y-auto custom-scrollbar p-12 lg:p-24 relative bg-black/20">
         {pg ? (
           <div className="max-w-4xl mx-auto space-y-16 animate-in fade-in duration-700">
              <div className="space-y-4">
                <p className="text-[10px] font-black text-fuchsia-500/40 uppercase tracking-[0.5em] ml-2">Sequence Entry</p>
                <input 
                  value={pg.title} 
                  onChange={e => onSave({...data, chronicles: data.chronicles.map(x => x.id === selArcId ? {...x, episodes: x.episodes.map(y => y.id === selEpId ? {...y, pages: y.pages.map(z => z.id === selPgId ? {...z, title: e.target.value} : z)} : y)} : x)})}
                  className="w-full bg-transparent border-none text-7xl font-serif italic text-white outline-none focus:text-fuchsia-500 transition-colors"
                  placeholder="ENTRY NAME"
                />
              </div>
              <textarea 
                value={pg.content}
                onChange={e => onSave({...data, chronicles: data.chronicles.map(x => x.id === selArcId ? {...x, episodes: x.episodes.map(y => y.id === selEpId ? {...y, pages: y.pages.map(z => z.id === selPgId ? {...z, content: e.target.value} : z)} : y)} : x)})}
                className="w-full bg-transparent text-2xl font-serif text-fuchsia-100/50 leading-[2.3] outline-none min-h-[60vh] resize-none selection:bg-fuchsia-500/30"
                placeholder="Begin log sequence..."
              />
           </div>
         ) : (
           <div className="h-full flex flex-col items-center justify-center opacity-10 space-y-10 animate-floating">
              <Layers size={120} className="text-fuchsia-500" />
              <p className="text-[10px] font-black tracking-[1.5em] uppercase text-fuchsia-500">Authorized selection required</p>
           </div>
         )}
      </div>
    </div>
  );
}

