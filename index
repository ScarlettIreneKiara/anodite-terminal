function TabBtn({ active, icon: Icon, label, onClick }) {
  return (
    <button onClick={onClick} className={`px-8 py-4 rounded-2xl flex items-center gap-3 transition-all border ${active ? 'bg-fuchsia-600 text-white border-fuchsia-500 shadow-lg shadow-fuchsia-900/20 scale-105' : 'bg-black/40 border-fuchsia-900/20 text-fuchsia-900 hover:text-fuchsia-400 hover:border-fuchsia-500/40'}`}>
      <Icon size={18} />
      <span className="text-[10px] font-black uppercase tracking-widest">{label}</span>
    </button>
  );
}

