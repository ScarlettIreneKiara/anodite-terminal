// --- READ MODE (FLOW) ---

function ReadMode({ data, phase, setPhase, selection, setActiveBioId }) {
  const { selArcId, setSelArcId, selEpId, setSelEpId, selPgId, setSelPgId } = selection;

  const arc = data.chronicles.find(a => a.id === selArcId);
  const ep = arc?.episodes.find(e => e.id === selEpId);
  const pg = ep?.pages.find(p => p.id === selPgId);

  const allPagesFlat = useMemo(() => {
    return data.chronicles.flatMap(a => 
      a.episodes.flatMap(e => 
        e.pages.map(p => ({ 
          ...p, 
          arcId: a.id, 
          epId: e.id, 
          arcTitle: a.title, 
          epTitle: e.title 
        }))
      )
    );
  }, [data.chronicles]);

  const currentIndex = allPagesFlat.findIndex(p => p.id === selPgId);

  const navigateToPage = (index) => {
    if (index >= 0 && index < allPagesFlat.length) {
      const p = allPagesFlat[index];
      setSelArcId(p.arcId);
      setSelEpId(p.epId);
      setSelPgId(p.id);
      setPhase('story');
    }
  };

  return (
    <div className="h-full w-full">
      <div className="max-w-5xl mx-auto px-10 py-24 min-h-full flex flex-col relative">
        <div className="flex-1 animate-in fade-in slide-in-from-bottom-8 duration-1000">
           {phase === 'title' && (
             <div className="flex flex-col items-center justify-center py-20 text-center space-y-16">
                <div className="relative animate-floating">
                  <div className="absolute inset-0 bg-fuchsia-500/30 blur-[100px] rounded-full" />
                  <OmnitrixLogo size={180} active={true} />
                </div>
                <div className="space-y-6">
                  <div className="flex flex-col items-center">
                    <span className="text-fuchsia-500 font-mono tracking-[1.5em] text-[10px] mb-4">EST. NEURAL LINK: ACTIVE</span>
                    <h1 className="text-8xl font-black tracking-tighter text-white uppercase leading-none drop-shadow-[0_0_30px_rgba(255,255,255,0.1)]">
                      {data.meta?.title?.split(' ').map((word, i) => (
                        <span key={i} className={i % 2 === 0 ? 'text-white' : 'text-fuchsia-600 block'}>{word} </span>
                      ))}
                    </h1>
                  </div>
                </div>
                <button onClick={() => setPhase('codex')} className="px-16 py-6 bg-fuchsia-600 text-white font-black rounded-[2.5rem] hover:bg-fuchsia-500 transition-all tracking-[0.4em] text-[10px] shadow-[0_0_40px_rgba(217,70,239,0.2)] uppercase group">
                  Begin Synchronization
                  <ChevronRight size={16} className="inline ml-2 group-hover:translate-x-1 transition-transform" />
                </button>
             </div>
           )}

           {phase === 'codex' && (
             <div className="space-y-16">
                <div className="border-b border-fuchsia-900/20 pb-12 flex flex-col md:flex-row justify-between items-start md:items-end gap-6">
                  <div className="space-y-2">
