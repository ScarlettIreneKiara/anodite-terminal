      <Icon size={sub ? 18 : 22} className={`${active ? 'drop-shadow-[0_0_8px_#d946ef]' : ''} transition-transform duration-500 ${active ? 'scale-110' : 'group-hover:scale-110'}`} />
      <span className={`font-black mt-2 tracking-[0.2em] uppercase ${sub ? 'text-[6px]' : 'text-[7px]'}`}>{label}</span>
      {active && (
        <>
          <div className="absolute right-0 w-1 h-8 bg-fuchsia-500 rounded-l-full shadow-[0_0_10px_#d946ef]" />
          <div className="absolute left-0 w-1 h-8 bg-fuchsia-500 rounded-r-full shadow-[0_0_10px_#d946ef]" />
        </>
      )}
    </button>
